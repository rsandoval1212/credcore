# CredCore - Variables de entorno
# Copiar a .env y personalizar antes de usar

# Django
SECRET_KEY=your-super-secret-key-change-this
DJANGO_SETTINGS_MODULE=config.settings.development

# Admin (usado por setup scripts)
CREDCORE_ADMIN_EMAIL=admin@credcore.local
CREDCORE_ADMIN_PASSWORD=CambiarEstaContraseña123!

# Base de datos (producción)
DB_NAME=credcore_db
DB_USER=credcore_user
DB_PASSWORD=db-password-here
DB_HOST=localhost
DB_PORT=5432

# SQLite (desarrollo)
USE_SQLITE=True
USE_REDIS=False

# Email
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
