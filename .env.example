# ═══════════════════════════════════════════════════════════════════════════════
# CredCore - Variables de Entorno
# Copiar a .env y personalizar ANTES de iniciar
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-strong-random-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Admin inicial ───────────────────────────────────────────────────────────
CREDCORE_ADMIN_EMAIL=admin@credcore.local
CREDCORE_ADMIN_PASSWORD=CambiarEstaContraseña123!

# ─── Base de datos ───────────────────────────────────────────────────────────
# Desarrollo: usar SQLite
USE_SQLITE=True

# Producción: PostgreSQL
DB_NAME=credcore_db
DB_USER=credcore_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis (opcional en desarrollo) ──────────────────────────────────────────
USE_REDIS=False
REDIS_URL=redis://localhost:6379/0

# ─── CORS ────────────────────────────────────────────────────────────────────
# Separar múltiples orígenes con coma
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Cookies (producción) ───────────────────────────────────────────────────
# COOKIE_DOMAIN=.credcore.com

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CredCore <noreply@credcore.com>

# ─── WhatsApp Business API ───────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Empresa ─────────────────────────────────────────────────────────────────
COMPANY_NAME=Mi Financiera S.A.
COMPANY_CURRENCY=DOP
COMPANY_CURRENCY_SYMBOL=RD$
TIME_ZONE=America/Santo_Domingo

# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# Crear como frontend/.env.local
# VITE_API_URL=/api/v1

# ─── Sentry (producción) ────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Storage S3 (producción) ────────────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
